{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/manifest.json", "/sw.js"]
  },
  "globalHeaders": {
    "Cache-Control": "no-cache",
    "X-Content-Type-Options": "nosniff"
  },
  "mimeTypes": {
    ".json": "application/json",
    ".js":   "application/javascript"
  }
}
